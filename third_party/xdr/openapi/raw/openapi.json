      "oAuth2": {
        "type": "oauth2",
        "flows": {
          "clientCredentials": {
            "tokenUrl": "https://visibility.amp.cisco.com/iroh/oauth2/token",
            "scopes": {
              "ao": "Cisco XDR Automation API access"
            }
          }
        }
      }
    },
